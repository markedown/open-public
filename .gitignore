# Rust build artifacts
/target

# Environment: only .env.example is tracked
.env
.env.*
!.env.example

# Local, uncommitted maintainer notes
CLAUDE.local.md

# Generated Tailwind stylesheet and the downloaded standalone CLI
/.bin/
/crates/server/static/app.css

# Uploaded image assets (ASSET_DIR default); runtime data, never committed
/data/

# Python bytecode from the scripts in scripts/, which CI and the docs both
# run. Importing one writes this next to it, and it is not ours to publish.
__pycache__/
*.pyc

# Editor and OS files
.DS_Store
*.swp
.idea/
.vscode/

# Tracked on purpose: .sqlx/ holds the offline query cache so CI builds
# without a live database. Do not add it here.
