#!/usr/bin/env bash
# Fast checks on every commit: block secrets, enforce formatting.
# Enable with: git config core.hooksPath .githooks
set -euo pipefail

command -v cargo >/dev/null 2>&1 || { [ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"; }

fail() {
  echo "pre-commit: $1" >&2
  exit 1
}

staged=$(git diff --cached --name-only --diff-filter=ACM)

# 1. Never commit an environment file. Only .env.example is tracked.
env_files=$(printf '%s\n' "$staged" | grep -E '^\.env($|\.)' | grep -vx '.env.example' || true)
if [ -n "$env_files" ]; then
  fail "refusing to commit environment file(s): $env_files"
fi

# 2. Scan added lines for high-signal secrets (the hook files themselves define
#    these patterns, so exclude them to avoid matching our own source).
if [ -n "$staged" ]; then
  if git diff --cached -U0 -- . ':(exclude).githooks' | grep '^+' \
      | grep -EqI 'BEGIN (RSA|OPENSSH|EC|DSA|PGP) PRIVATE KEY|AKIA[0-9A-Z]{16}|ghp_[0-9A-Za-z]{36}|xox[baprs]-[0-9A-Za-z-]{10,}|CLOUDFLARE_API_TOKEN=[^[:space:]]+'; then
    fail "a possible secret was found in the staged changes, aborting"
  fi
fi

# 3. Never commit private ingest code or local data/notes. The fixtures and any
#    local dump or notes file stay local. Under the ingest crate the rule is an
#    allowlist, not a pattern: the harvesting that reaches out to the world is
#    private, so only the files named here may be committed, and adding one is a
#    deliberate edit of this hook rather than a side effect of adding a file.
private_files=$(printf '%s\n' "$staged" | grep -E '^fixtures/|(^|/)[^/]+\.local\.(sql|md)$' || true)
public_ingest='crates/ingest/src/(main|lib|import)\.rs'
private_ingest=$(printf '%s\n' "$staged" | grep -E '^crates/ingest/src/' | grep -vE "^$public_ingest$" || true)
if [ -n "$private_files$private_ingest" ]; then
  fail "refusing to commit private code/data: $(printf '%s %s' "$private_files" "$private_ingest" | xargs)"
fi

# 4. The code, the docs and the commit messages stay country-agnostic and read
#    as ordinary human-authored work: no real politician names, no
#    country-specific dataset or source references, no AI attribution.
#
#    `dataset/` is exempt from the country-agnostic part, and only from that.
#    It holds the published dataset, which is country-specific by definition:
#    real people, real parties, and the official sources they were read from.
#    Publishing it is a deliberate decision, and it is released under CC0.
if [ -n "$staged" ]; then
  # AI attribution is never acceptable, in any file, including the dataset.
  everywhere=$(git diff --cached -U0 -- . ':(exclude).githooks' | grep '^+' || true)
  if printf '%s' "$everywhere" | grep -EqiI 'Co-Authored-By:[^$]*Claude|Generated with[^$]*Claude|AI-generated'; then
    fail "AI attribution found in staged changes"
  fi
  added=$(git diff --cached -U0 -- . ':(exclude).githooks' ':(exclude)dataset' | grep '^+' || true)
  if printf '%s' "$added" | grep -EqiI 'erdo[ğg]an|imamo[ğg]lu|lecornu|steinmeier|friedrich merz|\bTBMM\b|\bYSK\b|abgeordnetenwatch|bundeswahlleiter|congress-legislators|bioguide|\bODSEN\b|assemblee-nationale|data\.senat|secim[_ ]?id'; then
    fail "country-specific data or a real name found outside data/"
  fi
  emdash=$(printf '\342\200\224')  # U+2014 built from bytes, not embedded literally
  if printf '%s' "$added" | grep -q "$emdash"; then
    fail "em dash (U+2014) found in staged changes; use a comma, colon, or a hyphen"
  fi
fi

# 5. Formatting must be clean (fast; no compilation).
if command -v cargo >/dev/null 2>&1; then
  cargo fmt --all --check >/dev/null 2>&1 || fail "rustfmt check failed, run: cargo fmt --all"
fi

exit 0
