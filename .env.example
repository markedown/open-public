# Copy to .env and adjust. Never commit .env.

# --- Server ---
# If host port 5432 is taken, set POSTGRES_PORT to a free port and match it in
# DATABASE_URL below (docker compose reads POSTGRES_PORT from this file).
POSTGRES_PORT=5432
DATABASE_URL=postgres://open_public:open_public@localhost:5432/open_public
SITE_ADDR=127.0.0.1:3000
# Public origin used to build verification links and to decide whether session
# cookies carry the Secure attribute (an https origin turns Secure on).
PUBLIC_BASE_URL=http://127.0.0.1:3000
RUST_LOG=info,tower_http=info

# Secret used to HMAC-hash user emails. Required; the server refuses to start
# without it and warns while it is left at this development default. Generate a
# long random value in production (e.g. `openssl rand -hex 32`).
APP_SECRET=dev-only-change-me

# --- Email (Milestone 4) ---
# In dev, MAIL_TRANSPORT=console logs the verification code to the server log
# instead of sending, so no mail server is needed locally.
MAIL_TRANSPORT=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@example.com

# --- Tooling (not read by the server) ---
# Used by DNS/deploy scripts, not the application. Scoped API token.
CLOUDFLARE_API_TOKEN=
