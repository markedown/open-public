  "db_name": "PostgreSQL",
  "query": "\n        select id, wikidata_id, name, short_name, slug, founded_date, dissolved_date,\n               ideology_tags, summary, color\n        from parties\n        where country_id = $1\n          and (unaccent(name) ilike unaccent($2)\n               or unaccent(coalesce(short_name, '')) ilike unaccent($2))\n        order by name\n        ",
