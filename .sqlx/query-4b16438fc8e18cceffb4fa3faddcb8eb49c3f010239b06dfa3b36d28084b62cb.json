  "query": "\n        select p.full_name, p.slug, c.slug as \"country_slug?\", c.name as \"country_name?\"\n        from people p\n        left join countries c on c.id = p.country_id\n        where p.fts @@ to_tsquery('simple', $1)\n        order by p.full_name collate \"name_sort\"\n        limit $2\n        ",
