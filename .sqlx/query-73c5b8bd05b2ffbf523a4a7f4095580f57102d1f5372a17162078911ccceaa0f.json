  "query": "\n        select p.name, p.slug, c.slug as \"country_slug?\", c.name as \"country_name?\"\n        from parties p\n        left join countries c on c.id = p.country_id\n        where p.fts @@ to_tsquery('simple', $1)\n        order by p.name collate \"name_sort\"\n        limit $2\n        ",
