  "query": "\n        select pp.thesis_id, pp.party_id, pp.stance, pp.justification, s.url as source_url\n        from party_positions pp\n        join theses t on t.id = pp.thesis_id\n        join sources s on s.id = pp.source_id\n        where t.country_id = $1\n        ",
