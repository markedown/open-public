{
  "db_name": "PostgreSQL",
  "query": "\n        select n.id, n.headline, s.url as \"url!\", s.outlet,\n               n.summary_draft as \"summary_draft!\"\n        from news_items n\n        join sources s on s.id = n.source_id\n        where n.summary_draft is not null\n        order by s.published_at desc nulls last, n.id desc\n        ",
