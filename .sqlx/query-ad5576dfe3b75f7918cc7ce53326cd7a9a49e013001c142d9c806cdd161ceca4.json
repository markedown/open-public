{
  "db_name": "PostgreSQL",
  "query": "\n        select o.name, o.slug, o.logo_url, o.leaning,\n               (select count(*) from news_items n\n                join sources s on s.id = n.source_id\n                where s.outlet_id = o.id) as \"article_count!\"\n        from outlets o\n        where o.country_id = $1\n        order by o.name collate \"name_sort\"\n        ",
