{
  "db_name": "PostgreSQL",
  "query": "\n        select e.name as election_name, e.slug as election_slug,\n               e.held_on, r.seats, r.votes, e.valid_votes\n        from election_results r\n        join elections e on e.id = r.election_id\n        where r.party_id = $1\n        order by e.held_on desc nulls last, e.id desc\n        ",
