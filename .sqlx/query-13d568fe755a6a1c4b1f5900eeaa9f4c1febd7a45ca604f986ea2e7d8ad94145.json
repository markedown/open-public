  "db_name": "PostgreSQL",
  "query": "\n        select s.id, s.user_id, s.expires_at, u.is_admin as \"is_admin!\"\n        from sessions s\n        join users u on u.id = s.user_id\n        where s.token_hash = $1 and s.expires_at > now() and u.banned_at is null\n        ",
