{
  "db_name": "PostgreSQL",
  "query": "\n            select e.name, e.slug, co.slug as \"country_slug!\", e.held_on\n            from elections e join countries co on co.id = e.country_id\n            where e.country_id = any($1)\n            order by e.held_on desc nulls last, e.id desc\n            limit $2\n            ",
