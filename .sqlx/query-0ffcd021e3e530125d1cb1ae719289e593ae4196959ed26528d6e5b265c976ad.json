{
  "db_name": "PostgreSQL",
  "query": "\n        select st.id, st.text_original, st.is_paraphrase, st.stated_at,\n               s.url as \"url!\", s.outlet\n        from statements st\n        join sources s on s.id = st.source_id\n        where st.person_id = $1\n        order by st.stated_at desc nulls last, st.id desc\n        ",
