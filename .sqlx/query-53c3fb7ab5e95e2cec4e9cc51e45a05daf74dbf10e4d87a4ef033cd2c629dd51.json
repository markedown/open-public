  "query": "\n        select p.slug as \"poll_slug!\", o.position as \"option_position!\",\n               v.cast_at, v.voter_index\n        from poll_votes v\n        join polls p on p.id = v.poll_id\n        join poll_options o on o.id = v.option_id\n        order by p.slug, v.voter_index, o.position\n        ",
