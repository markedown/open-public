{
  "db_name": "PostgreSQL",
  "query": "\n        select n.id, n.headline, s.url as \"url!\"\n        from news_items n\n        join sources s on s.id = n.source_id\n        where n.our_summary is null and n.summary_draft is null\n        order by s.published_at desc nulls last, n.id desc\n        limit $1\n        ",
