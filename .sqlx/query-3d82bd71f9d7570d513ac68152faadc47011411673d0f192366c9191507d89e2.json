  "query": "\n        select t.id, t.text, t.position, tp.name as \"topic?\"\n        from theses t\n        left join topics tp on tp.id = t.topic_id\n        where t.country_id = $1 and t.scope = $2\n        order by t.position, t.id\n        ",
