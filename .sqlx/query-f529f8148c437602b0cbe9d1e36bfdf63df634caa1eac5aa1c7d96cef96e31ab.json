  "query": "\n        select id, wikidata_id, full_name, slug, birth_date, birth_place,\n               photo_url, photo_license, summary\n        from people\n        where country_id = $1 and unaccent(full_name) ilike unaccent($2)\n        order by full_name collate \"name_sort\"\n        limit $3 offset $4\n        ",
