  "query": "\n        select distinct p.id, p.full_name, p.slug\n        from people p\n        join position_evidence e on e.person_id = p.id\n        join theses t on t.id = e.thesis_id\n        where t.country_id = $1 and t.scope = 'person'\n        ",
