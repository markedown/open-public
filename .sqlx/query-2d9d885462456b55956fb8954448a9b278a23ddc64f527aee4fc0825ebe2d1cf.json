  "db_name": "PostgreSQL",
  "query": "\n        select o.id, o.label, o.position, o.media_url, count(v.id) as \"votes!\"\n        from poll_options o\n        left join poll_votes v on v.option_id = o.id\n        where o.poll_id = $1\n        group by o.id\n        order by o.position\n        ",
