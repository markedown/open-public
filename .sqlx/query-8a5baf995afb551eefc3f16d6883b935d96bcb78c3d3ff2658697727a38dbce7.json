{
  "db_name": "PostgreSQL",
  "query": "\n        select r.role_type, r.title, r.org, r.district,\n               r.start_date, r.end_date,\n               s.id as \"source_id!\", s.url as \"source_url!\"\n        from roles r\n        join sources s on s.id = r.source_id\n        where r.person_id = $1\n        order by r.start_date desc nulls last\n        ",
